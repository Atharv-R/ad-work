# .env.example

# LLM Provider: "groq" (free) or "openai" (paid, better structured output)
LLM_PROVIDER=groq

# Groq (free tier)
GROQ_API_KEY=your_groq_api_key_here

# OpenAI (optional, for production demos)
OPENAI_API_KEY=your_openai_api_key_here

# Database
DUCKDB_PATH=data/adwork.duckdb

# Logging
LOG_LEVEL=INFO